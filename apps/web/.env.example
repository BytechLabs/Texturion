# Copy to .env.local (gitignored) for development. Values come from the Supabase
# project (Settings → API). These are the only variables the browser bundle
# receives (SPEC §10); src/env.ts fails the build loudly when any is missing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=
# Optional: Cloudflare Turnstile site key (Cloudflare dashboard → Turnstile).
# When set, signup/login/reset-password render the captcha and pass its token
# to Supabase Auth; leave blank for local dev (Supabase captcha disabled).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Optional: the app portal origin (production: https://app.loonext.com). When
# set, the middleware enforces the marketing/app host split (D27) — leave
# blank for local dev so every route stays reachable on localhost.
NEXT_PUBLIC_APP_ORIGIN=
