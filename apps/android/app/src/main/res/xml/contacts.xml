<?xml version="1.0" encoding="utf-8"?>
<!--
    #183, part 3: tells the system Contacts app how to render the Loonext account's
    custom data rows. Each ContactsDataKind maps one of our MIME types to an icon
    + the columns to show: summaryColumn (DATA2) is the action label the sync
    adapter writes ("Call with Loonext" / "Text with Loonext"), detailColumn
    (DATA3) is the formatted number. Tapping a row fires a VIEW intent on the row,
    which MainActivity resolves back to the number (see contactsActionKind).

    The two mimeType values MUST match callMimeType()/textMimeType() in
    ContactsSyncPlan.kt (vnd.android.cursor.item/vnd.<applicationId>.call|.text).
-->
<ContactsAccountType xmlns:android="http://schemas.android.com/apk/res/android">
    <ContactsDataKind
        android:mimeType="vnd.android.cursor.item/vnd.com.loonext.android.call"
        android:icon="@drawable/ic_contacts_call"
        android:summaryColumn="data2"
        android:detailColumn="data3" />
    <ContactsDataKind
        android:mimeType="vnd.android.cursor.item/vnd.com.loonext.android.text"
        android:icon="@drawable/ic_contacts_text"
        android:summaryColumn="data2"
        android:detailColumn="data3" />
</ContactsAccountType>
