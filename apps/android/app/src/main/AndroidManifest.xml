<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Calls (#155): softphone audio + self-managed telecom integration. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- #171 (§9.1): the call FGS Jetpack Telecom runs is of type `phoneCall`;
         that FGS is what grants mic capture over the keyguard / backgrounded. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- REMOVED (§9.2): USE_FULL_SCREEN_INTENT (the OS posts its own ring),
         FOREGROUND_SERVICE_MICROPHONE (the calling FGS is `phoneCall`, not
         `microphone`), and VIBRATE (the OS owns ring vibration). -->
    <!-- Notifications (#156): Android 13+ runtime permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".LoonextApp"
        android:label="Loonext"
        android:icon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Loonext.Starting">

        <!-- singleTask: the browser's OAuth redirect must return to the RUNNING
             instance via onNewIntent, not stack a new one in the browser task. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Google sign-in PKCE redirect (#166). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.loonext.android" android:host="auth-callback" />
            </intent-filter>
        </activity>

        <!-- #171 (§6): the dedicated full-screen IncomingCallActivity is DELETED
             — Android Telecom renders the over-keyguard incoming UI. No app
             Activity presents the ring. -->

        <!-- FCM entry point (#156): message + token-refresh delivery. -->
        <service
            android:name=".push.LoonextMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- #171 (§6): the self-managed LoonextConnectionService and the
             CallActionReceiver are DELETED — Jetpack Telecom registers and binds
             the ConnectionService itself (on API 34+) and owns the incoming
             answer/decline actions. CallsManager.registerAppWithTelecom is what
             registers the self-managed PhoneAccount now. -->
    </application>
</manifest>
