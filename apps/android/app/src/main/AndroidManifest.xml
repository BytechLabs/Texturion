<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Calls (#155): softphone audio + self-managed telecom integration. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- #171 (§9.1): the call FGS Jetpack Telecom runs is of type `phoneCall`;
         that FGS is what grants mic capture over the keyguard / backgrounded. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- CORRECTION (§6, device-verified): androidx.core.telecom registers a
         SELF-MANAGED call and Android draws NO system incoming UI for one — so the
         app posts its own CallStyle ring with a full-screen intent (the earlier
         "the OS posts its own ring" premise was wrong; calls never rang). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Notifications (#156): Android 13+ runtime permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".LoonextApp"
        android:label="Loonext"
        android:icon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Loonext.Starting">

        <!-- singleTask: the browser's OAuth redirect must return to the RUNNING
             instance via onNewIntent, not stack a new one in the browser task. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Google sign-in PKCE redirect (#166). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.loonext.android" android:host="auth-callback" />
            </intent-filter>
        </activity>

        <!-- #171 (§6, RESTORED): the full-screen over-keyguard incoming target for
             the CallStyle ring's fullScreenIntent. Telecom (self-managed) shows no
             OS incoming UI, so the app owns the ring surface. showWhenLocked +
             turnScreenOn present it over the lock screen; excludeFromRecents +
             noHistory keep it out of the task history. -->
        <activity
            android:name=".features.calls.IncomingCallActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />

        <!-- FCM entry point (#156): message + token-refresh delivery. -->
        <service
            android:name=".push.LoonextMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- #171 (§6, RESTORED): Answer/Decline on the CallStyle ring broadcast
             here; the receiver drives the Telecom call via SoftphoneManager. -->
        <receiver
            android:name=".telephony.CallActionReceiver"
            android:exported="false" />
    </application>
</manifest>
