# Local bindings for `wrangler dev`: copy to .dev.vars (gitignored) and fill in.
# In production these are Worker encrypted secrets (`wrangler secret put <NAME>`),
# injected from GitHub Actions environment secrets — never committed (SPEC §10).
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
# The Telnyx Call-Control application id (voice "connection") per-company numbers
# bind to for inbound voice — the target of the missed-call text-back webhooks.
TELNYX_VOICE_CONNECTION_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
SENTRY_DSN=
APP_ORIGIN=
API_ORIGIN=
RESEND_FROM=
# Web Push VAPID key pair (SPEC §8) — generate once with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Stripe catalog ids — printed by `pnpm --filter @loonext/api stripe:setup`
# (run once per Stripe mode with STRIPE_SECRET_KEY set; SPEC §9).
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_STARTER_OVERAGE_PRICE_ID=
STRIPE_PRO_OVERAGE_PRICE_ID=
STRIPE_US_FEE_PRICE_ID=
# Module add-on price ids — also printed by `stripe:setup`; schema-optional (the
# Worker boots without them) but required to sell the add-ons (#12 plan builder).
STRIPE_MODULE_MMS_PRICE_ID=
STRIPE_MODULE_VOICE_PRICE_ID=
STRIPE_MODULE_EXTRA_STORAGE_PRICE_ID=
STRIPE_MODULE_REGIONS_CA_PRICE_ID=
STRIPE_SMS_METER_EVENT_NAME=sms_segments
# OPTIONAL — PostHog Cloud project API key (SPEC §12 step 18). Leave unset to
# disable product analytics entirely (captures become silent no-ops).
POSTHOG_API_KEY=
