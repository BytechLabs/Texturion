# Local bindings for `wrangler dev`: copy to .dev.vars (gitignored) and fill in.
# In production these are Worker encrypted secrets (`wrangler secret put <NAME>`),
# injected from GitHub Actions environment secrets — never committed (SPEC §10).
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
SENTRY_DSN=
APP_ORIGIN=
